const { 
    default: makeWASocket, 
    useMultiFileAuthState, 
    DisconnectReason, 
    fetchLatestBaileysVersion 
} = require("@whiskeysockets/baileys");
const pino = require("pino");
const { Boom } = require("@hapi/boom");

const BOT_NAME = "𝑩𝑶𝑻 𝑺𝒐𝒏𝒈 𝑱𝒊𝒏 𝑾𝒐𝒐";

async function startSongJinWoo() {
    // تم تغيير اسم المجلد لضمان جلسة جديدة ونظيفة
    const { state, saveCreds } = await useMultiFileAuthState('session_auth_final');
    const { version } = await fetchLatestBaileysVersion();
    
    const socket = makeWASocket({
        version,
        auth: state,
        logger: pino({ level: 'silent' }), // تم تحويلها لـ silent لتقليل زحام السجلات
        printQRInTerminal: false,
        browser: ["Ubuntu", "Chrome", "20.0.04"]
    });

    socket.ev.on('creds.update', saveCreds);

    socket.ev.on('connection.update', async (update) => {
        const { connection, lastDisconnect, qr } = update;

        if (connection === 'open') {
            console.log("\n" + "=".repeat(40));
            console.log(`تم تشغيل ${BOT_NAME} بنجاح!`);
            console.log("=".repeat(40) + "\n");
        } 
        
        else if (connection === 'close') {
            let reason = new Boom(lastDisconnect?.error)?.output.statusCode;
            if (reason === DisconnectReason.restartRequired) {
                startSongJinWoo();
            } else if (reason !== DisconnectReason.loggedOut) {
                setTimeout(() => startSongJinWoo(), 5000);
            }
        }

        // طلب كود الربط
        if (!socket.authState.creds.registered) {
            const phoneNumber = "201055719273"; 
            setTimeout(async () => {
                try {
                    let code = await socket.requestPairingCode(phoneNumber);
                    console.log("\n" + "╔" + "═".repeat(30) + "╗");
                    console.log(`  كود الربط لـ ${BOT_NAME}`);
                    console.log(`  الكود هو: ${code}`);
                    console.log("╚" + "═".repeat(30) + "╝\n");
                } catch (err) {
                    console.error("فشل طلب الكود، جاري إعادة المحاولة...");
                }
            }, 10000); // زيادة الوقت لضمان استقرار السيرفر
        }
    });

    socket.ev.on('messages.upsert', async (chatUpdate) => {
        try {
            const m = chatUpdate.messages[0];
            if (!m.message || m.key.fromMe) return;

            // استخراج النص بطريقة آمنة
            const messageType = Object.keys(m.message)[0];
            const text = messageType === 'conversation' ? m.message.conversation :
                         messageType === 'extendedTextMessage' ? m.message.extendedTextMessage?.text :
                         messageType === 'imageMessage' ? m.message.imageMessage?.caption :
                         messageType === 'videoMessage' ? m.message.videoMessage?.caption : '';

            if (!text) return; // إذا لم يوجد نص، تجاهل الرسالة
            const sender = m.key.remoteJid;
            const pushName = m.pushName || "مستخدم";

            // نظام الأوامر بالنقطة
            if (text.startsWith('.')) {
                const command = text.slice(1).trim();

                if (command === 'السلام عليكم') {
                    const response = `وعليكم السلام يا *${pushName}*! 🫡\n\nأنا *${BOT_NAME}*، كيف يمكنني مساعدتك اليوم؟\n\n_البوت يعمل بنجاح_ ✅`;
                    await socket.sendMessage(sender, { text: response }, { quoted: m });
                }
                
                if (command === 'الحالة') {
                    await socket.sendMessage(sender, { text: `البوت متصل ويعمل بكفاءة! 🚀\nالاسم: ${BOT_NAME}` }, { quoted: m });
                }
            }
        } catch (err) {
            console.error("خطأ في معالجة الرسالة:", err);
        }
    });
}

startSongJinWoo().catch(err => console.error("خطأ غير متوقع:", err));
